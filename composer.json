{
    "name": "orlinkzz/waha-php",
    "description": "PHP client for WAHA (WhatsApp HTTP API) with built-in anti-banned flow",
    "type": "library",
    "license": "MIT",
    "keywords": ["whatsapp", "waha", "bot", "api", "laravel"],
    "authors": [
        {
            "name": "Orlinkzz",
            "email": "me@senimankode.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Orlinkzz\\Waha\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Orlinkzz\\Waha\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Orlinkzz\\Waha\\Laravel\\WahaServiceProvider"
            ],
            "aliases": {
                "Waha": "Orlinkzz\\Waha\\Laravel\\WahaFacade"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
